{
  "manifest_version": 3,
  "name": "NanoAgent",
  "version": "1.1",
  "permissions": [
    "sidePanel",
    "scripting",
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Open NanoAgent"
  }
}